{
  "name": "vantage-ai",
  "private": true,
  "version": "4.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "server-dev": "node --watch server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security:env": "node scripts/scan-vite-secrets.mjs",
    "security:audit": "npm audit --audit-level=moderate",
    "check": "npm run security:env && npm run typecheck && npm run build",
    "backend:check": "node --check server.js && node --check backend/scheduler.js",
    "backend:startup-test": "node -e \"import('./server.js').then(() => { console.log('server.js imports OK'); process.exit(0); }).catch(e => { console.error('ERROR', e.message); process.exit(1); })\"",
    "postinstall": "node scripts/install-quant-deps.js || true",
    "build:android": "npm run build && npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@google/genai": "^1.43.0",
    "@revenuecat/purchases-capacitor": "^13.2.0",
    "@sentry/node": "^10.45.0",
    "@types/react-router-dom": "^5.3.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.23.26",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "http-proxy-middleware": "^3.0.5",
    "isomorphic-dompurify": "^2.16.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.562.0",
    "node-cron": "^4.2.1",
    "openai": "^6.25.0",
    "pino": "^10.3.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router": "^7.17.0",
    "react-router-dom": "^7.17.0",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.13",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.1.1",
    "node-forge": "^1.4.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.9",
    "workbox-window": "^7.4.0"
  },
  "overrides": {
    "@google-cloud/firestore": "^8.6.0",
    "gaxios": "^7.1.5",
    "google-gax": "^5.0.7",
    "retry-request": "^8.0.3",
    "teeny-request": "^10.1.3",
    "uuid": "^14.0.0"
  }
}
