# ==============================================================================
# VANTAGE AI — ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Instructions:
# 1. Copy this file to `.env.local` for local development.
# 2. NEVER commit `.env.local` to version control.
# 3. For production, add these variables to your hosting platforms:
#    - VITE_* variables go to Netlify / Vercel (Frontend)
#    - Non-VITE variables (and VITE_ADMIN_API_SECRET) go to Railway / Render (Backend)

# ── FRONTEND (VITE) ENVIRONMENT VARIABLES ─────────────────────────────────────

# Firebase Config (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Push Notifications (Optional - from Cloud Messaging tab)
VITE_FIREBASE_VAPID_KEY=your_vapid_key

# Fapshi Payment Gateway (from Fapshi Dashboard)
VITE_FAPSHI_USER_TOKEN=your_fapshi_user_token
VITE_FAPSHI_API_KEY=your_fapshi_api_key

# Selar Payment Gateway Links (Direct checkout URLs for VIP plans)
VITE_SELAR_DAILY_LINK=https://selar.co/your_daily_link
VITE_SELAR_WEEKLY_LINK=https://selar.co/your_weekly_link
VITE_SELAR_MONTHLY_LINK=https://selar.co/your_monthly_link
VITE_SELAR_ANNUAL_LINK=https://selar.co/your_annual_link

# Admin Configuration (email of the super-admin account)
VITE_ADMIN_EMAIL=your_admin_email@example.com

# Backend Connection URL (Local: http://localhost:8080, Prod: your_railway_url)
VITE_BACKEND_URL=your_backend_url

# Administrator API Secret (Must match the backend ADMIN_API_SECRET perfectly)
VITE_ADMIN_API_SECRET=your_admin_secret_string

# Alternative/Legacy APIs (Optional)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_JSONBIN_API_KEY=your_jsonbin_api_key
VITE_FOOTBALL_API_KEY=your_rapidapi_football_key


# ── BACKEND (NODE.JS / EXPRESS) ENVIRONMENT VARIABLES ─────────────────────────
# These variables should be set in your backend hosting environment (e.g., Railway).
# Note: In local development, the backend reads from .env.local as well.

# Google Gemini AI (from Google AI Studio: aistudio.google.com)
GOOGLE_GENAI_API_KEY=your_gemini_api_key

# Sportmonks API (from sportmonks.com - used for advanced match stats/odds)
SPORTMONKS_API_TOKEN=your_sportmonks_api_token

# Administrator API Secret (Must match VITE_ADMIN_API_SECRET on the frontend)
ADMIN_API_SECRET=your_admin_secret_string

# Firebase Admin SDK (Service Account JSON string, minified to a single line)
# From Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"vantage-ai-4d17d","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}