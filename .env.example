# Vantage AI — Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.

# Firebase Config (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Gemini AI (from Google AI Studio: aistudio.google.com)
VITE_GOOGLE_GENAI_API_KEY=your_gemini_api_key

# Fapshi Payment Gateway (from Fapshi Dashboard)
VITE_FAPSHI_USER_TOKEN=your_fapshi_user_token
VITE_FAPSHI_API_KEY=your_fapshi_api_key

# Admin Configuration (email of the super-admin account)
VITE_ADMIN_EMAIL=your_admin_email@example.com

# API-Football (from RapidAPI: rapidapi.com/api-sports/api/api-football)
VITE_FOOTBALL_API_KEY=04cba64676b082424fa4422e305a82d4