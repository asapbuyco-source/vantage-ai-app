rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    function isVip() {
      return signedIn()
        && exists(/databases/$(database)/documents/profiles/$(request.auth.uid))
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isVip == true;
    }

    function doesNotTouchProtectedFields() {
      let protected = ['isVip', 'vipExpiry', 'vipPlan', 'totalPaid', 'isAdmin', 'isBlocked',
        'referralEarnings', 'lifetimeEarnings', 'referralCount'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(protected);
    }

    match /profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          "uid", "email", "displayName", "isVip", "isAdmin", "isBlocked",
          "referralCode", "referralCount", "referralEarnings", "lifetimeEarnings",
          "createdAt"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.isVip == false
        && request.resource.data.isAdmin == false
        && request.resource.data.isBlocked == false
        && request.resource.data.referralCount == 0
        && request.resource.data.referralEarnings == 0
        && request.resource.data.lifetimeEarnings == 0;

      allow update: if (
        isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          "isVip", "vipExpiry", "vipPlan", "totalPaid", "isAdmin", "isBlocked",
          "referralEarnings", "lifetimeEarnings", "referralCount"
        ])
      ) || isAdmin();
    }

    match /referral_codes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /daily_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /basketball_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cricket_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /daily_blogs/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /generation_locks/{dateStr} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /team_assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if docId in ['app', 'app_stats'];
      allow write: if isAdmin();
    }

    match /settings/internal {
      allow read, write: if isAdmin();
    }

    match /payout_requests/{reqId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.amount is number
        && request.resource.data.amount >= 1000
        && request.resource.data.keys().hasOnly([
          "userId", "userEmail", "amount", "phoneNumber", "status", "date", "paymentMethod"
        ]);
      allow get: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /vault_days/{docId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /selar_pending/{refId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.used == false
        && request.resource.data.plan in ["daily", "weekly", "monthly", "quarterly", "annual"];
      allow update: if false;
      allow delete: if false;
    }

    match /selar_unmatched/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /live_scores/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /match_news/{dateStr} {
      allow read: if true;
      allow write: if false;
    }

    match /quant_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /quant_predictions/{dateStr}/picks/{pickId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /quant_vip/{dateStr} {
      allow read: if isVip();
      allow write: if isAdmin();
    }

    // Arbitrage opportunities — VIP only, backend writes only
    match /arbitrage_bets/{docId} {
      allow read: if isVip();
      allow write: if false;
    }

    match /elo_ratings/{teamId} {
      allow read: if false;
      allow write: if false;
    }
    match /quant_performance/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /fapshi_transactions/{transId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update, delete: if false;
    }

    match /push_subscriptions/{subId} {
      allow read, write: if false;
    }

    match /processed_emails/{msgId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /match_stats/{dateStr} {
      allow read: if true;
      allow write: if false;
    }
    match /fixture_odds/{fixtureId} {
      allow read: if true;
      allow write: if false;
    }
    match /h2h_data/{h2hId} {
      allow read: if true;
      allow write: if false;
    }
    match /lineups/{fixtureId} {
      allow read: if true;
      allow write: if false;
    }
    match /match_facts/{dateStr} {
      allow read: if true;
      allow write: if false;
    }
    match /static_cache/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /payment_intents/{docId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if false;
      allow update, delete: if false;
    }

    match /payment_transactions/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
