rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global helper: Check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    // Profiles: Users can read/write their own profile. Admins can read all.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId || isAdmin();
    }
    
    // Daily Predictions: Publicly readable. Writes are admin-only (via Admin SDK).
    match /daily_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Basketball Predictions: Same pattern as daily_predictions.
    match /basketball_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Daily Blogs: Publicly readable. Written by backend only.
    match /daily_blogs/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Generation Locks: Authenticated users can orchestrate AI generation
    match /generation_locks/{dateStr} {
      allow read, write: if request.auth != null;
    }
    
    // Team Assets: Publicly readable for team logos
    match /team_assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Settings / App Stats: Publicly readable. Only admins can write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Payouts (legacy collection, kept for backwards compat)
    match /payouts/{reqId} {
       allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
       allow read, update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Payout Requests (actual collection used by AuthContext)
    match /payout_requests/{reqId} {
       allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
       allow read, update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
    
    // Selar pending tokens — owner can read/create their own token only.
    // Marking as used (write after creation) is done via runTransaction by the authenticated owner.
    match /selar_pending/{refId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && resource.data.used == false;
      allow delete: if false;
    }
  }
}
