rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global helper: Check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    // Profiles: Users can read/write their own profile. Admins can read all.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId || isAdmin();
    }
    
    // Daily Predictions: Publicly readable for the Landing Page and Public Stats
    match /daily_predictions/{dateStr} {
      allow read: if true;
      allow write: if request.auth != null; 
    }
    
    // Generation Locks: Authenticated users can orchestrate AI generation
    match /generation_locks/{dateStr} {
      allow read, write: if request.auth != null;
    }
    
    // Team Assets: Publicly readable for team logos
    match /team_assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Settings / App Stats: Publicly readable for the track record page
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Payouts: Users can request, admins can process
    match /payout_requests/{reqId} {
       allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
       allow read, update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
    
    // Selar pending tokens
    match /selar_pending/{refId} {
      allow read, write: if true; // Accessed via API webhooks
    }
  }
}
