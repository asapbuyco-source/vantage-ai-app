rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global helper: Check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAdmin == true;
    }

    // Helper: Checks that a write does NOT touch VIP or admin-sensitive fields.
    // This prevents client-side free VIP bypass.
    function doesNotTouchProtectedFields() {
      let protected = ['isVip', 'vipExpiry', 'vipPlan', 'totalPaid', 'isAdmin', 'isBlocked'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(protected);
    }

    // Profiles: Users can read all profiles (needed for referral lookup).
    // Users can ONLY update their own NON-protected fields.
    // VIP/admin fields can only be written by the backend (Admin SDK bypasses all rules).
    match /profiles/{userId} {
      allow read: if request.auth != null;
      // Allow create (new user signup) — only if creating their own profile, isVip defaults false
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.isVip == false
        && request.resource.data.isAdmin == false
        && request.resource.data.isBlocked == false;
      // Allow update only if NOT touching protected fields, or if admin
      allow update: if (request.auth != null && request.auth.uid == userId && doesNotTouchProtectedFields())
        || isAdmin();
    }
    
    // Daily Predictions: Publicly readable. Writes are admin-only (via Admin SDK).
    match /daily_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Basketball Predictions: Same pattern as daily_predictions.
    match /basketball_predictions/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Daily Blogs: Publicly readable. Written by backend only.
    match /daily_blogs/{dateStr} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Generation Locks: Authenticated users can orchestrate AI generation
    match /generation_locks/{dateStr} {
      allow read, write: if request.auth != null;
    }
    
    // Team Assets: Publicly readable for team logos
    match /team_assets/{assetId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Settings / App Stats: Publicly readable. Only admins can write.
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Payouts (legacy collection, kept for backwards compat)
    match /payouts/{reqId} {
       allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
       allow read, update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Payout Requests (actual collection used by AuthContext)
    match /payout_requests/{reqId} {
       allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
       allow read, update: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
    
    // Selar pending tokens — owner can read and CREATE their own token only.
    // Updates are FORBIDDEN client-side — only the backend Admin SDK can mark tokens as used.
    // This prevents plan spoofing (changing daily→annual before payment completes).
    match /selar_pending/{refId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.used == false;
      // No client-side update — backend Admin SDK handles marking as used
      allow update: if false;
      allow delete: if false;
    }

    // Selar unmatched payments — written by backend only, admins can read for review
    match /selar_unmatched/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Backend only
    }
  }
}
